# My Holiday
MY_HOLIDAY_ENABLE_LIVE=false
AMADEUS_ENV=test

# Database (Neon Postgres)
DATABASE_URL=

# Amadeus (Flights + Hotels)
# Register at https://developers.amadeus.com/ → Get started → Create app
# Same credentials power both Flight Offers API and Hotel Offers API
# Hotel integration: Hotel List API (by city) + Hotel Offers API (availability + pricing)
# Set AMADEUS_ENV=test for sandbox, AMADEUS_ENV=production for live
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Kiwi/Tequila (Flights) — supports booking deep links + discovery mode
# Register at https://tequila.kiwi.com/ → Dashboard → Get API key
# Features: flight search, location lookup, booking verification, multi-destination discovery
KIWI_API_KEY=

# Flight provider priority: "amadeus" or "kiwi"
# When both keys are set, this controls which provider is tried first
# Fallback: if primary fails, the other provider is tried automatically
FLIGHT_PROVIDER=amadeus

# Booking.com via RapidAPI (live hotel data — second provider alongside Amadeus)
# Register at https://rapidapi.com/ → Subscribe to Booking.com API
# Provides real-time pricing, reviews, photos from Booking.com
# Hotels use: Amadeus (live) + Booking.com (live) + local DB (210+ hotels, 27 cities)
RAPIDAPI_KEY=

# Optional: Weather provider
OPENWEATHER_API_KEY=
